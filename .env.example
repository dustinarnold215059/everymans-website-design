# ─────────────────────────────────────────────────────────────────────────────
# Every Man's Website Design — environment variables
# Copy this file to `.env.local` and fill in real values. Never commit .env.local.
# ─────────────────────────────────────────────────────────────────────────────

# Resend — transactional email for the contact form. https://resend.com/api-keys
RESEND_API_KEY=

# Where contact-form submissions are delivered (your inbox).
EMAIL_TO=Dustin.t.arnold215059@gmail.com

# The "from" address Resend sends as. Must be a verified domain/sender in Resend.
# During testing you may use Resend's sandbox sender: onboarding@resend.dev
EMAIL_FROM=Every Man's Website Design <hello@everymanswebsitedesign.com>

# Upstash Redis — rate limiting for the contact form. https://console.upstash.com
# If these are left blank, the form still works but rate limiting is disabled (dev).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Public site URL (used for canonical/OG/sitemap). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://everymanswebsitedesign.com
